# The frontend talks ONLY to the chatbot backend, never to KMRAG.
# In dev, Vite proxies /api to this target (see vite.config.ts).
VITE_API_TARGET=http://127.0.0.1:5000

# For a production build where the API is same-origin, leave VITE_API_BASE_URL empty.
# Set it only if the API is served from a different origin.
VITE_API_BASE_URL=
