# ==========================================================================
# Chatbot Platform — Backend environment example
# Copy to `.env` and fill in real values locally. NEVER commit the real .env.
# ==========================================================================

# ── Flask ─────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=change_me
JWT_SECRET_KEY=change_me
# Access/refresh token lifetimes (seconds)
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=1209600

# ── PostgreSQL (source of truth for the chatbot app) ──────────
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=chatbot
POSTGRES_USER=webuser
POSTGRES_PASSWORD=change_me
# Optional: fully-formed URL overrides the discrete vars above.
# DATABASE_URL=postgresql+psycopg://webuser:pass@127.0.0.1:5432/chatbot

# ── Database bootstrap (see `flask init-db`) ──────────────────
# Boot-time schema handling:
#   DB_AUTO_UPGRADE=true    -> create-if-missing + run migrations at startup
#   DB_REQUIRE_CURRENT=true -> refuse to boot when the schema is behind head
# Default (both unset/false): log a warning if behind, but still boot.
DB_AUTO_UPGRADE=false
DB_REQUIRE_CURRENT=false

# ── Seed data (required default: the first Super Admin) ───────
# Read by `flask init-db`, `flask seed --super-admin`, `scripts/seed.py`, and the
# boot-time auto-setup (DB_AUTO_UPGRADE). The Super Admin is created automatically
# during the first database setup/migration so you can log in right away.
# If these are left unset, a built-in default is used instead:
#   email: admin@chatbot.local   password: Admin@123456   (CHANGE IT after first login)
SEED_SUPERADMIN_EMAIL=admin@yourco.com
SEED_SUPERADMIN_PASSWORD=change_me_strong
SEED_SUPERADMIN_NAME=Super Admin
# Optional: password for the sample-tenant admin (only with --sample-tenant).
# SEED_TENANT_ADMIN_PASSWORD=change_me_strong

# ── Redis (cache / sessions / rate limit / token revocation) ──
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Cache TTLs (seconds)
CACHE_TTL_KB_SECONDS=300
CACHE_TTL_TENANT_SECONDS=300

# ── OpenAI (general answers, classification, chat titles) ─────
OPENAI_API_KEY=sk-your-openai-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_ROUTER_MODEL=gpt-4o-mini

# ── KMRAG internal RAG engine (never exposed to the frontend) ─
KMRAG_BASE_URL=http://127.0.0.1:8000
KMRAG_UPLOAD_ENDPOINT=/upload
KMRAG_RETRIEVAL_ENDPOINT=/query
KMRAG_REQUEST_TIMEOUT_SECONDS=120
KMRAG_MAX_RETRY_COUNT=2
# KMRAG only accepts these models on /query:
KMRAG_QUERY_MODEL=gpt-4o-mini

# ── Uploads ───────────────────────────────────────────────────
MAX_UPLOAD_FILE_SIZE_MB=2
ALLOWED_FILE_EXTENSIONS=pdf,docx,txt,csv,xlsx,jpg,jpeg,png,md
UPLOAD_TMP_DIR=/tmp/chatbot-uploads

# ── Retrieval defaults (configurable, never hardcoded) ────────
RAG_TOP_K=6
RAG_ALPHA=0.5
# Vector-leg cosine threshold for qualifying KMRAG sources. Keep aligned with
# KMRAG MIN_RETRIEVAL_SCORE (Synthora-AI-dev/.env) — it gates on the same signal.
RAG_MIN_RELEVANCE_SCORE=0.32

# ── Chat answer cache (exact repeats within one conversation) ──
# Seconds a repeated identical question is served from Redis. 0 disables.
CHAT_ANSWER_CACHE_TTL_SECONDS=3600

# ── Rate limiting (per user, sliding window) ──────────────────
RATE_LIMIT_CHAT_PER_MINUTE=30
RATE_LIMIT_UPLOAD_PER_MINUTE=10

# ── Model pricing (USD per 1,000,000 tokens). JSON. No hardcoded prices. ──
MODEL_PRICING_JSON={"gpt-4o-mini":{"input_per_1m_tokens":0.15,"output_per_1m_tokens":0.60},"gpt-4o":{"input_per_1m_tokens":2.50,"output_per_1m_tokens":10.00}}

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true
